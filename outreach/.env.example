# ── Mode ─────────────────────────────────────────────────────────────────────
DRY_RUN=true
SEND_ENABLED=false

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=sqlite:///./outreach.db

# ── Sender identity (REQUIRED before live sending) ───────────────────────────
SENDER_NAME=Your Name
BUSINESS_NAME=EEN Construction
BUSINESS_EMAIL=contact@eenconstruction.com
BUSINESS_PHONE=(240) 555-0100
BUSINESS_WEBSITE=https://eenconstruction.com
PHYSICAL_MAILING_ADDRESS=123 Main St, Silver Spring, MD 20901
UNSUBSCRIBE_URL=https://eenconstruction.com/unsubscribe

# ── Email provider (choose one; others can be blank) ─────────────────────────
EMAIL_PROVIDER=resend
RESEND_API_KEY=
SENDGRID_API_KEY=
POSTMARK_SERVER_TOKEN=
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=

# ── Contact enrichment (optional) ────────────────────────────────────────────
HUNTER_API_KEY=
APOLLO_API_KEY=
PDL_API_KEY=

# ── Email verification (optional) ────────────────────────────────────────────
ZEROBOUNCE_API_KEY=
NEVERBOUNCE_API_KEY=

# ── Sending limits ────────────────────────────────────────────────────────────
MAX_EMAILS_PER_DAY=20
MAX_EMAILS_PER_HOUR=5
MAX_PER_COMPANY=2
MIN_LEAD_SCORE=40
MIN_EMAIL_CONFIDENCE=0.7
REINTRO_COOLDOWN_DAYS=120
MAX_FOLLOWUPS=2
BOUNCE_RATE_STOP=0.03
COMPLAINT_RATE_STOP=0.001

# ── Data sources ──────────────────────────────────────────────────────────────
MONTGOMERY_DATASET_ID=et5s-xste
SOCRATA_APP_TOKEN=
